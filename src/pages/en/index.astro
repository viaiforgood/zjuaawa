---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout lang="en" title="ZJUAANC Washington Hub" description="Connecting and serving ZJU alumni in Washington State and overseas, fostering strong local and international networks." path="/en/">
  <div class="max-w-4xl mx-auto px-6 space-y-12">
    <!-- Hero -->
    <header class="text-center py-10 space-y-4">
      <div class="inline-flex items-center gap-x-2 bg-blue-950/40 text-blue-400 px-4 py-1.5 rounded-full text-xs font-semibold border border-blue-900/30">
        <span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-ping"></span>
        <span>ZJUAANC Official Liaison Hub</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-slate-200 leading-tight mt-2">
        ZJUAANC<br><span class="ai-gradient">Washington Hub</span>
      </h1>
      <p class="max-w-2xl mx-auto text-slate-400 text-base md:text-lg leading-relaxed">
        Connecting and serving ZJU alumni in Washington State and overseas, fostering strong local and international networks.
      </p>
    </header>

    <!-- Announcement Banner -->
    <a href="https://zjuaanc.org/2026-07-22-first-north-american-chinese-ai-music-competition/" target="_blank" class="block bg-gradient-to-r from-blue-900/30 via-indigo-950/20 to-blue-900/30 border border-blue-800/40 rounded-3xl p-5 hover:border-blue-500/50 transition-all group shadow-xl relative overflow-hidden">
      <div class="absolute -right-16 -top-16 w-36 h-36 bg-blue-500/5 rounded-full blur-2xl group-hover:bg-blue-500/10 transition-colors"></div>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 relative z-10">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0 text-blue-400 group-hover:scale-110 transition-transform">
            <i class="fa-solid fa-music"></i>
          </div>
          <div>
            <div class="text-sm font-bold text-slate-200 flex items-center gap-x-2">
              <span>The 1st North American Chinese AI Music Creative Competition</span>
              <span class="bg-blue-500/20 text-blue-300 text-[10px] px-2 py-0.5 rounded-full border border-blue-500/30">Ongoing</span>
            </div>
            <div class="text-xs text-slate-400 mt-1 leading-relaxed">Celebrating ZJU's 130th Anniversary & ZJUAA NC's 15th Anniversary. Click to view the official announcement post!</div>
          </div>
        </div>
        <div class="flex items-center gap-x-1.5 text-xs text-blue-400 font-semibold group-hover:translate-x-1 transition-transform self-end sm:self-center shrink-0">
          <span>View Notice</span>
          <i class="fa-solid fa-arrow-right"></i>
        </div>
      </div>
    </a>

    <!-- Hero Image Banner -->
    <div class="relative w-full h-48 md:h-64 rounded-3xl overflow-hidden border border-slate-900 shadow-2xl bg-slate-900 flex items-center justify-center group">
      <img src="/images/hero.jpg" alt="Hero Banner" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.015]" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
    </div>

    <!-- Local Contact Section -->
    <section class="bg-slate-900/30 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
      <h2 class="text-xl font-bold text-slate-200 flex items-center gap-x-2">
        <i class="fa-solid fa-location-dot text-blue-500"></i>
        <span>Local Liaison Representative</span>
      </h2>
      <div class="bg-blue-950/20 border border-blue-900/20 p-5 rounded-2xl flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-blue-600/10 text-blue-400 border border-blue-500/20 flex items-center justify-center font-bold text-lg shrink-0">
            WA
          </div>
          <div>
            <div class="text-base sm:text-lg font-bold text-slate-200 leading-snug">Xiao Qi (Director, Washington State & Overseas)</div>
            <div class="text-xs text-slate-500 mt-1">Responsible for alumni connections, inquiries, and local support.</div>
            <div class="text-xs text-blue-400 mt-2 flex items-center gap-x-1.5 justify-start">
              <i class="fa-regular fa-envelope"></i>
              <a href="mailto:wa@zjuaanc.org" class="hover:underline">wa@zjuaanc.org</a>
            </div>
          </div>
        </div>
        <div class="flex flex-col items-center gap-1.5 shrink-0 mx-auto md:mx-0">
          <img src="/images/wechat_group_qr_wa.jpg" alt="WeChat Group QR" class="w-20 h-20 rounded-lg border border-slate-800" />
          <span class="text-[10px] text-slate-500">Scan QR Code</span>
        </div>
      </div>
    </section>

    <!-- Global Liaison Directory -->
    <section class="space-y-6">
      <h2 class="text-xl font-bold text-slate-200 flex items-center gap-x-2 border-b border-slate-900 pb-3">
        <i class="fa-solid fa-address-book text-blue-500"></i>
        <span>Liaison Department Directory (Executive Committee)</span>
      </h2>
      <p class="text-xs text-slate-400 leading-relaxed">
        ZJU Alumni Association in North America, North Carolina Chapter Liaison Officers:
      </p>
      
<div class="grid sm:grid-cols-2 gap-4">
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Xiao Qi <span class="text-xs text-slate-500 font-normal">(Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: Washington State & Overseas</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Xiangwu Zhang <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: NC RTP Region & Universities</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Naiquan Zheng <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: NC Non-RTP Region & Financial Institutions</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Gang Xu <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: Mainland China Sister Alumni Associations</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Qin Huang <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: Texas & Scientific Research Organizations</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Zhangxin Shen <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: Washington D.C. & Government Agencies</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Lei Qi <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: Mainland China & Alma Mater</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Michael Huo <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: California, Tennessee, North American Sister Organizations & North American Sister Alumni Associations</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Wenbo Zhang <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: Florida & Chinese Schools / Orgs</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-slate-200 text-sm">Weining Xu <span class="text-xs text-slate-500 font-normal">(Vice Director)</span></div>
    <div class="text-xs text-slate-400 mt-1">Responsibility: NC Coast, Smoky Mountains & Church Fellowships</div>
  </div>
</div>

    </section>
  </div>
</BaseLayout>
