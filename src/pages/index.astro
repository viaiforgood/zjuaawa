---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout lang="zh-CN" title="北卡浙大校友会华盛顿州站" description="连接与服务华盛顿州及海外地区的浙江大学校友，构建强大的本地与国际校友网络。" path="/">
  <div class="max-w-4xl mx-auto px-6 space-y-12">
    <!-- Hero -->
    <header class="text-center py-10 space-y-4">
      <div class="inline-flex items-center gap-x-2 bg-blue-950/40 text-blue-400 px-4 py-1.5 rounded-full text-xs font-semibold border border-blue-900/30">
        <span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-ping"></span>
        <span>北卡浙大校友会 官方联络站 (ZJUAANC Hub)</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-tight mt-2">
        北卡浙大校友会<br><span class="ai-gradient">华盛顿州站</span>
      </h1>
      <p class="max-w-2xl mx-auto text-slate-400 text-base md:text-lg leading-relaxed">
        连接与服务华盛顿州及海外地区的浙江大学校友，构建强大的本地与国际校友网络。
      </p>
    </header>

    <!-- Hero Image Banner -->
    <div class="relative w-full h-48 md:h-64 rounded-3xl overflow-hidden border border-slate-900 shadow-2xl bg-slate-900 flex items-center justify-center group">
      <img src="/images/hero.jpg" alt="Hero Banner" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.015]" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
    </div>

    <!-- Local Contact Section -->
    <section class="bg-slate-900/30 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
      <h2 class="text-xl font-bold text-white flex items-center gap-x-2">
        <i class="fa-solid fa-location-dot text-blue-500"></i>
        <span>本站联络人</span>
      </h2>
      <div class="bg-blue-950/20 border border-blue-900/20 p-5 rounded-2xl flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-blue-600/10 text-blue-400 border border-blue-500/20 flex items-center justify-center font-bold text-lg shrink-0">
            WA
          </div>
          <div>
            <div class="text-base sm:text-lg font-bold text-white leading-snug">戚霄（部长，华盛顿州和海外）</div>
            <div class="text-xs text-slate-500 mt-1">负责本地区及相关机构的校友联系、咨询与互助</div>
            <div class="text-xs text-blue-400 mt-2 flex items-center gap-x-1.5 justify-start">
              <i class="fa-regular fa-envelope"></i>
              <a href="mailto:wa@zjuaanc.org" class="hover:underline">wa@zjuaanc.org</a>
            </div>
          </div>
        </div>
        <div class="flex flex-col items-center gap-1.5 shrink-0 mx-auto md:mx-0">
          <img src="/images/wechat_group_qr_wa.jpg" alt="微信群二维码" class="w-20 h-20 rounded-lg border border-slate-800" />
          <span class="text-[10px] text-slate-500">微信扫码入群</span>
        </div>
      </div>
    </section>

    <!-- Global Liaison Directory -->
    <section class="space-y-6">
      <h2 class="text-xl font-bold text-white flex items-center gap-x-2 border-b border-slate-900 pb-3">
        <i class="fa-solid fa-address-book text-blue-500"></i>
        <span>校友会联络部组织架构 (总部执委会)</span>
      </h2>
      <p class="text-xs text-slate-400 leading-relaxed">
        北卡浙大校友会联络部部长及各地区/行业分部副部长：
      </p>
      
<div class="grid sm:grid-cols-2 gap-4">
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">戚霄 <span class="text-xs text-slate-500 font-normal">（部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：华盛顿州和海外</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">张向武 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：北卡RTP地区和高校</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">郑乃权 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：北卡非RTP地区和金融财务机构</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">徐刚 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：中国大陆姊妹校友会</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">黄勤 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：德州和科研机构</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">沈章鑫 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：华盛顿特区和政府机构</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">祁蕾 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：中国大陆和母校</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">霍明旭 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：加州、田纳西州、和北美姊妹机构、和北美姊妹校友会联络</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">张文博 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：佛州和中文学校等机构</div>
  </div>
  <div class="bg-slate-900/60 border border-slate-900/60 p-4 rounded-xl">
    <div class="font-bold text-white text-sm">徐卫宁 <span class="text-xs text-slate-500 font-normal">（副部长）</span></div>
    <div class="text-xs text-slate-400 mt-1">负责领域：北卡海岸和大烟山地区和教会团契</div>
  </div>
</div>

    </section>
  </div>
</BaseLayout>
